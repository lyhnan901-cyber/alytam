# ============================================================================
# مؤسسة اليتامى الخيرية التنموية — متغيرات البيئة
# ============================================================================
#
# هذا الملف نموذج. انسخه إلى ".env" وعدّل القيم. لا تلتزم ".env" في Git.
#
# يدعم التطبيق تعدد الفروع (Multi-Branch) من خلال نفس الـ deployment:
#   - branch1.<domain>  → يستخدم متغيرات VITE_BRANCH1_*
#   - branch2.<domain>  → يستخدم متغيرات VITE_BRANCH2_*
#   - أي subdomain آخر أو localhost → يستخدم VITE_SUPABASE_URL الافتراضي
#
# في التطوير المحلي يكفي ضبط الافتراضي (VITE_SUPABASE_URL +
# VITE_SUPABASE_PUBLISHABLE_KEY) وسيستخدمه التطبيق.
# ============================================================================

# ---------- الإعدادات الافتراضية (تُستخدم على localhost أو أي subdomain غير مذكور أدناه)
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""

# ---------- الفرع الأول (branch1.<domain>)
# اتركها فارغة إن لم يُستخدم Multi-Branch — التطبيق سيستخدم القيم الافتراضية.
VITE_BRANCH1_SUPABASE_URL=""
VITE_BRANCH1_SUPABASE_PUBLISHABLE_KEY=""

# ---------- الفرع الثاني (branch2.<domain>)
# املأ هذه القيم بعد إنشاء مشروع Supabase الجديد للفرع الثاني وتشغيل
# supabase/bootstrap.sql عليه. راجع supabase/README.md للخطوات الكاملة.
VITE_BRANCH2_SUPABASE_URL=""
VITE_BRANCH2_SUPABASE_PUBLISHABLE_KEY=""
